rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function myStaffDoc() { return /databases/$(database)/documents/staff/$(request.auth.uid); }
    function myStaffExists() { return signedIn() && exists(myStaffDoc()); }
    function myGarageId() { return myStaffExists() ? get(myStaffDoc()).data.garageId : null; }
    function role() { return myStaffExists() ? get(myStaffDoc()).data.role : null; }
    function isSuperAdmin() { return signedIn() && role() == "superadmin"; }
    function isAdmin() { return signedIn() && role() == "admin"; }
    function isMech() { return signedIn() && role() == "mechanic"; }
    function inGarage(garageId) { return myStaffExists() && garageId == myGarageId(); }

    match /garages/{garageId} {
      allow read: if isSuperAdmin() || inGarage(garageId);
      allow create, update, delete: if isSuperAdmin();

      match /settings/{docId} {
        allow read: if isSuperAdmin() || inGarage(garageId);
        allow write: if isSuperAdmin() || (isAdmin() && inGarage(garageId));
      }

      match /customers/{id} {
        allow read: if isSuperAdmin() || inGarage(garageId);
        allow create: if isSuperAdmin()
          || ((isAdmin() || isMech()) && inGarage(garageId))
          || (
            request.resource.data.keys().hasOnly(["garageId","name","fullName","phone","email","address","notes","createdAt","source"])
            && request.resource.data.garageId == garageId
            && (request.resource.data.name is string || request.resource.data.fullName is string)
            && request.resource.data.phone is string
            && request.resource.data.email is string
            && request.resource.data.address is string
            && request.resource.data.notes is string
            && (request.resource.data.source == "client_self_register" || request.resource.data.source == "client_registration")
          );
        allow update: if isSuperAdmin() || ((isAdmin() || isMech()) && inGarage(garageId));
        allow delete: if isSuperAdmin() || (isAdmin() && inGarage(garageId));
      }

      match /vehicles/{id} {
        allow read: if isSuperAdmin() || inGarage(garageId);
        allow create: if isSuperAdmin()
          || ((isAdmin() || isMech()) && inGarage(garageId))
          || (
            request.resource.data.keys().hasOnly(["garageId","customerId","make","model","year","plate","vin","mileage","currentKm","engineType","cylinders","bodyType","color","notes","createdAt","source"])
            && request.resource.data.garageId == garageId
            && request.resource.data.customerId is string
            && request.resource.data.make is string
            && request.resource.data.model is string
            && (!request.resource.data.keys().hasAny(["year"]) || request.resource.data.year is number || request.resource.data.year == null)
            && (!request.resource.data.keys().hasAny(["plate"]) || request.resource.data.plate is string)
            && (!request.resource.data.keys().hasAny(["vin"]) || request.resource.data.vin is string)
            && (!request.resource.data.keys().hasAny(["mileage"]) || request.resource.data.mileage is number || request.resource.data.mileage == null)
            && (!request.resource.data.keys().hasAny(["currentKm"]) || request.resource.data.currentKm is number || request.resource.data.currentKm == null)
            && request.resource.data.engineType is string
            && request.resource.data.cylinders is string
            && request.resource.data.bodyType is string
            && request.resource.data.color is string
            && request.resource.data.notes is string
            && (request.resource.data.source == "client_self_register" || request.resource.data.source == "client_registration")
          );
        allow update: if isSuperAdmin() || ((isAdmin() || isMech()) && inGarage(garageId));
        allow delete: if isSuperAdmin() || (isAdmin() && inGarage(garageId));
      }

      match /workorders/{id} {
        allow read: if isSuperAdmin()
          || (isAdmin() && inGarage(garageId))
          || (isMech() && inGarage(garageId) && resource.data.assignedTo == request.auth.uid);
        allow create: if isSuperAdmin() || ((isAdmin() || isMech()) && inGarage(garageId));
        allow update: if isSuperAdmin() || ((isAdmin() || isMech()) && inGarage(garageId));
        allow delete: if isSuperAdmin() || (isAdmin() && inGarage(garageId));
      }

      match /invoices/{id} {
        allow read: if isSuperAdmin() || inGarage(garageId);
        allow create, update, delete: if isSuperAdmin() || (isAdmin() && inGarage(garageId));
      }

      match /parts/{id} {
        allow read: if isSuperAdmin() || inGarage(garageId);
        allow create, update: if isSuperAdmin() || ((isAdmin() || isMech()) && inGarage(garageId));
        allow delete: if isSuperAdmin() || (isAdmin() && inGarage(garageId));
      }

      match /expenses_parts/{id} {
        allow read: if isSuperAdmin() || inGarage(garageId);
        allow create, update: if isSuperAdmin() || ((isAdmin() || isMech()) && inGarage(garageId));
        allow delete: if isSuperAdmin() || (isAdmin() && inGarage(garageId));
      }

      match /promotions/{id} {
        allow read: if isSuperAdmin() || inGarage(garageId);
        allow create, update, delete: if isSuperAdmin() || (isAdmin() && inGarage(garageId));
      }

      match /logs/{id} {
        allow read: if isSuperAdmin() || (isAdmin() && inGarage(garageId));
        allow create: if isSuperAdmin() || inGarage(garageId);
        allow delete: if isSuperAdmin() || (isAdmin() && inGarage(garageId));
      }

      match /invites/{id} {
        allow read: if isSuperAdmin() || (isAdmin() && inGarage(garageId));
        allow create, update, delete: if isSuperAdmin() || (isAdmin() && inGarage(garageId));
      }
    }

    match /staff/{uid} {
      allow read: if (signedIn() && request.auth.uid == uid) || isSuperAdmin() || (isAdmin() && resource.data.garageId == myGarageId());
      allow write: if isSuperAdmin() || (isAdmin() && request.resource.data.garageId == myGarageId());
    }

    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /mail/{id} {
      allow create: if signedIn();
      allow read, update, delete: if false;
    }
  }
}
