rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    function myUserDoc() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function role() {
      return exists(myUserDoc()) ? get(myUserDoc()).data.role : null;
    }

    function isAdmin() { return signedIn() && role() == "admin"; }
    function isMech()  { return signedIn() && role() == "mechanic"; }

    // USERS
    // - Lecture: chacun lit son doc
    // - Création: un utilisateur peut créer son doc avec role SI invite valide (inviteCode)
    // - Update: l'utilisateur peut update son doc SANS changer role (évite escalade)
    // - Admin: gère tout
    match /users/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;

      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role in ["admin","mechanic"]
        && request.resource.data.inviteCode is string
        && exists(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode))
        && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode)).data.email == request.auth.token.email
        && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode)).data.role == request.resource.data.role
        && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode)).data.used != true;

      allow update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.role == resource.data.role;

      allow create, update, delete: if isAdmin();
    }

    // INVITES (admin crée, utilisateur lit/consume)
    match /invites/{code} {
      allow read: if signedIn();
      allow create, delete: if isAdmin();

      // l'utilisateur (même email) peut marquer used=true sans modifier email/role/code
      allow update: if signedIn()
        && request.auth.token.email == resource.data.email
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.code == resource.data.code
        && request.resource.data.used == true;
    }

    match /customers/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /vehicles/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /workorders/{id} {
      allow read: if isAdmin()
        || (isMech() && resource.data.assignedTo == request.auth.uid);

      allow create: if isAdmin();

      allow update: if isAdmin()
        || (isMech()
            && resource.data.assignedTo == request.auth.uid
            && request.resource.data.assignedTo == resource.data.assignedTo);

      allow delete: if isAdmin();
    }

    match /appointments/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /promotions/{id} {
      allow read, create, update, delete: if isAdmin();
    }

    match /invoices/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /meta/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /mail/{id} {
      allow read, create, update, delete: if isAdmin();
    }
  }
}
