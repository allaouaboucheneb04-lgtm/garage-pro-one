rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    // user doc du compte connecté (évite les boucles)
    function myUserDoc() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function role() {
      // si le doc n'existe pas encore, rôle vide
      return exists(myUserDoc()) ? get(myUserDoc()).data.role : null;
    }

    function isAdmin() { return signedIn() && role() == "admin"; }
    function isMech()  { return signedIn() && role() == "mechanic"; }

    // IMPORTANT: ne pas utiliser isAdmin() dans la règle READ de /users,
    // sinon ça peut créer une boucle avec role() -> get(/users/{uid})
    match /users/{uid} {
      // chaque user peut lire SON doc (nécessaire pour role())
      allow read: if signedIn() && request.auth.uid == uid;

      // seul un admin peut écrire (changer roles, etc.)
      allow create, update, delete: if isAdmin();
    }

    match /customers/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /vehicles/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /workorders/{id} {
      allow read: if isAdmin()
        || (isMech() && resource.data.assignedTo == request.auth.uid);

      allow create: if isAdmin();

      allow update: if isAdmin()
        || (isMech()
            && resource.data.assignedTo == request.auth.uid
            && request.resource.data.assignedTo == resource.data.assignedTo);

      allow delete: if isAdmin();
    }

    match /appointments/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // Promotions (création / envoi) : réservé admin
    match /promotions/{id} {
      allow read, create, update, delete: if isAdmin();
    }

    // File d'envoi email utilisée par l'extension "Trigger Email from Firestore"
    // (collection configurée = "mail")
    match /mail/{id} {
      allow read, create, update, delete: if isAdmin();
    }

    match /meta/{id} {
      allow read, write: if isAdmin();
    }
  }
}
